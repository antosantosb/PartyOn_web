// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("ADMIN") // ADMIN, STAFF
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  auditLogs      AuditLog[]
  scannedTickets Ticket[]   @relation("ScannedTickets")
}

model Event {
  id          String      @id @default(cuid())
  name        String      @default("PARTY ON EVENT")
  status      EventStatus @default(DRAFT)
  tagline     String?  // Subtítulo bajo el nombre del evento
  date        String   @default("SÁBADO 15 NOVIEMBRE")
  startsAt    DateTime?
  endsAt      DateTime?
  location    String   @default("BRAGA")
  artistInfo  String   @default("DJ SANTOS")
  lineup      String?  // Artistas separados por comas

  // Customization
  logoText1    String   @default("PARTY")
  logoText2    String   @default("ON")
  emailSubject String   @default("Entrada para PartyOn")
  emailBody    String   @default("Gracias por tu compra. Te adjuntamos tu entrada en este correo.") @db.Text

  ticketTypes TicketType[]
  theme       Theme?
  tickets     Ticket[]
  expenses    Expense[]
  orders      Order[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Theme {
  id              String   @id @default(cuid())
  eventId         String   @unique
  event           Event    @relation(fields: [eventId], references: [id])
  
  primaryColor    String   @default("#00ffcc")
  secondaryColor  String   @default("#ff007f")
  backgroundImage       String?  
  backgroundImageMobile String?  
  ticketTemplate        String?  

  updatedAt       DateTime @updatedAt
}

model TicketType {
  id           String    @id @default(cuid())
  eventId      String
  event        Event     @relation(fields: [eventId], references: [id])
  
  name         String
  price        Float
  maxStock     Int       @default(0)
  soldCount    Int       @default(0)
  saleStartsAt DateTime?
  saleEndsAt   DateTime?
  forceSoldOut Boolean   @default(false)
  isArchived   Boolean   @default(false)

  tickets Ticket[]
}

model Order {
  id            String   @id @default(cuid())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id])
  customerName  String
  customerEmail String
  totalPaid     Float
  paymentIntent String?  @unique
  status        String   @default("COMPLETED")
  createdAt     DateTime @default(now())
  tickets       Ticket[]
}

model Ticket {
  id            String     @id @default(cuid())
  eventId       String
  event         Event      @relation(fields: [eventId], references: [id])
  ticketTypeId  String
  ticketType    TicketType @relation(fields: [ticketTypeId], references: [id])
  
  orderId       String?
  order         Order?     @relation(fields: [orderId], references: [id])
  
  email         String
  name          String
  status        String     @default("VALID") // VALID, USED, CANCELLED
  paymentIntent String?
  pricePaid     Float      @default(0)
  
  scannedAt     DateTime?
  scannedById   String?
  scannedBy     User?      @relation("ScannedTickets", fields: [scannedById], references: [id])
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Expense {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id])
  name        String
  amount      Float
  category    String   @default("GENERAL") // e.g. VENUE, DJ, SECURITY, BAR
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  severity  String   @default("INFO")
  action    String
  details   String?  @db.Text
  timestamp DateTime @default(now())
}
